# ==============================================
# クチコミラボ 環境変数設定
# ==============================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# --- データベース ---
# MySQL接続URL
DATABASE_URL=mysql://username:password@localhost:3306/kuchikomi_lab

# --- 認証 ---
# JWTセッション署名用シークレット（32文字以上のランダム文字列）
JWT_SECRET=your-jwt-secret-change-me-to-random-string

# OAuthサーバーURL（認証プロバイダーのURL）
OAUTH_SERVER_URL=https://your-oauth-server.example.com

# アプリケーションID（OAuthクライアントID）
VITE_APP_ID=kuchikomi-lab

# --- Stripe決済 ---
# Stripeシークレットキー（sk_test_ または sk_live_）
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Webhook署名シークレット（whsec_）
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe公開キー（pk_test_ または pk_live_）
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Price ID（各プラン）- Stripeダッシュボードで作成後に設定
STRIPE_PRICE_LIGHT=price_XXXXXXXXXXXXXXXXXX
STRIPE_PRICE_STANDARD=price_XXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PREMIUM=price_XXXXXXXXXXXXXXXXXX

# --- OpenAI ---
# OpenAI APIキー（口コミ生成に使用）
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXX

# --- サーバー ---
# ポート番号（デフォルト: 3000）
PORT=3000
